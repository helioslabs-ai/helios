# ============================================================
# Helios — Environment Variables
# Copy to .env and fill in values before running helios setup
# ============================================================

# X Layer
XLAYER_RPC_URL=https://rpc.xlayer.tech

# OKX OnchainOS
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Agent wallets — create via: onchainos wallet create --name <role>
CURATOR_ACCOUNT_ID=
CURATOR_WALLET_ADDRESS=0x
STRATEGIST_ACCOUNT_ID=
STRATEGIST_WALLET_ADDRESS=0x
SENTINEL_ACCOUNT_ID=
SENTINEL_WALLET_ADDRESS=0x
EXECUTOR_ACCOUNT_ID=
EXECUTOR_WALLET_ADDRESS=0x

# Contracts — set after: forge script script/Deploy.s.sol --broadcast
HELIOS_REGISTRY_ADDRESS=0x

# Deployer key — forge only, never loaded by agents
DEPLOYER_PRIVATE_KEY=0x

# AI
OPENAI_API_KEY=

# Uniswap Trading API — register at developers.uniswap.org
UNISWAP_API_KEY=

# Database (Supabase + Drizzle)
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional — OKX Aave product IDs on X Layer (auto-detected if unset; USDG defaults to 33906)
HELIOS_AAVE_USDC_INVESTMENT_ID=
HELIOS_AAVE_USDG_INVESTMENT_ID=

# Runtime
API_URL=http://localhost:3001
ENABLE_AGENTS=false
CHECK_INTERVAL_MINUTES=60
